# Bloquea cualquier acceso directo por navegador a esta carpeta.
# Las llaves (.pem) solo deben leerse desde PHP (file_get_contents),
# nunca ser descargables por URL.
#
# NOTA IMPORTANTE: este archivo es una mitigación, no una solución
# definitiva. Lo correcto es mover Privatekey.pem y PublicKey.pem fuera
# del document root (por ejemplo, a una carpeta hermana del proyecto que
# Apache no sirva), y ajustar $privateKeyPath / $publicKeyPath en
# FirmaDigital.php para apuntar a esa nueva ubicación. Además:
#  - Privatekey.pem NUNCA debe subirse a Git (agrégalo a .gitignore).
#  - Si esta llave ya fue subida al repositorio, se considera comprometida:
#    genera un nuevo par de llaves y revoca/reemplaza la anterior.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
